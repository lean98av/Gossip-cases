{
  "name": "gossip-cases",
  "version": "1.0.0",
  "description": "E-commerce Monolítico (TypeScript + Sequelize + PostgreSQL)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate:migrate:create": "sequelize-cli migrate:create"
  },
  "keywords": [
    "ecommerce",
    "typescript",
    "sequelize"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-standard": "^5.0.0",
    "prettier": "^3.2.5",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lean98av/Gossip-cases.git"
  },
  "homepage": "https://github.com/lean98av/Gossip-cases#readme"
}
