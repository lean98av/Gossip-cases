<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gossip Cases - Accesorios celulares</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/home.css">
</head>

<% function getImageMimeType(filename) {
    const ext = filename?.split('.').pop()?.toLowerCase();
    const types = {
        jpg: 'image/jpeg',
        jpeg: 'image/jpeg',
        png: 'image/png',
        gif: 'image/gif',
        webp: 'image/webp',
    };
    return types[ext] || 'image/jpeg';
} %>

    <body>
        <%- include('partials/topbar') %>

            <!-- MAIN CONTENT -->
            <div class="container py-5">

                <h1 class="mb-4">
                    🛒 Mi carrito
                </h1>

                <% if(cart.length===0){ %>

                    <div class="alert alert-info">
                        Tu carrito está vacío
                    </div>

                    <% } else { %>

                        <div class="row">

                            <div class="col-lg-8">

                                <% cart.forEach(item=> { %>

                                    <div class="card mb-3 border-0 shadow-sm rounded-4">

                                        <div class="card-body d-flex align-items-center gap-3">

                               <% 
                                const imgSource = item.image 
                                    ? `data:${getImageMimeType(item.image.name)};base64,${item.image.file}` 
                                    : '/images/logo.png'; 
                                %>
                                <img src="<%= imgSource %>"
                                    class="card-img-top product-img" alt="<%= item.name %>" style="
                                        width:90px;
                                        height:90px;
                                        object-fit:cover;
                                        border-radius:18px;
                                    ">


                                            <div class="flex-grow-1">

                                                <h5>
                                                    <%= item.name %>
                                                </h5>

                                                <div>
                                                    Cantidad:
                                                    <strong>
                                                        <%= item.quantity %>
                                                    </strong>
                                                </div>

                                                <div class="text-primary fw-bold fs-5">
                                                    $<%= item.price %>
                                                </div>

                                            </div>

                                            <form action="/cart/remove/<%= item.id %>" method="POST">
                                                <button class="btn btn-danger rounded-pill">
                                                    ✕
                                                </button>
                                            </form>

                                        </div>

                                    </div>

                                    <% }) %>

                            </div>

                            <div class="col-lg-4">

                                <div class="card border-0 shadow rounded-4">

                                    <div class="card-body">

                                        <h3>
                                            Total
                                        </h3>

                                        <h2 class="mb-4">
                                           $<%= Number(total).toFixed(2) %>
                                        </h2>
                                        <%
                                        let message = `Hola! Quiero realizar el siguiente pedido de Gossip Cases:\n\n`;

                                        cart.forEach(item => {

                                            const price = Number(item.price);
                                            const quantity = Number(item.quantity);

                                            const subtotal = price * quantity;

                                            message += `${item.name} x${quantity} = $${subtotal.toFixed(2)}\n`;

                                        });

                                        message += `\n--------------------------\n`;
                                        message += `TOTAL: $${Number(total).toFixed(2)}\n\n`;
                                        message += `Gracias.`;

                                        const whatsappUrl = `https://wa.me/5491126517287?text=${encodeURIComponent(message)}`;
                                        %>

                                        <a
                                            target="_blank"
                                            href="<%= whatsappUrl %>"
                                            class="btn btn-success w-100 rounded-pill"
                                        >
                                            Finalizar por WhatsApp
                                        </a>
                                    </div>

                                </div>

                            </div>

                        </div>

                        <% } %>

            </div>


            <%- include('partials/footer') %>

                <script
                    src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    </body>

</html>