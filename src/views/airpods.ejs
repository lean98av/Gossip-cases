<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gossip Cases - Accesorios celulares</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/home.css">
</head>

<% function getImageMimeType(filename) {
       const ext = filename?.split('.').pop()?.toLowerCase();
       const types = {
         jpg: 'image/jpeg',
         jpeg: 'image/jpeg',
         png: 'image/png',
         gif: 'image/gif',
         webp: 'image/webp',
       };
       return types[ext] || 'image/jpeg';
     }
 %>

<body>
    <%- include('partials/topbar') %>

        <!-- MAIN CONTENT -->
        <div class="container mt-4">

            <!-- FILTROS -->
            <div class="filters-section mb-4">
                <div class="row g-3">

                    <div class="col-md-4 col-sm-6">
                        <label class="form-label fw-bold">
                            Ordenar por
                        </label>

                        <select class="form-select form-select-sm">
                            <option>Menor Precio</option>
                            <option>Mayor Precio</option>
                            <option>Nombre Asc</option>
                            <option>Nombre Desc</option>
                        </select>
                    </div>

                </div>
            </div>

            <!-- GRID DE PRODUCTOS -->
            <div class="row g-4 mb-5">

                <% if(products && products.length> 0) { %>

                    <% products.forEach(product=> { %>

                        <div class="col-6 col-md-4 col-lg-3">

                            <a href="/product/<%= product.id %>" class="text-decoration-none text-reset">

                                <div class="card product-card">

                                    <% if (product.images && product.images.length > 0) { %>
                                    <img src="data:<%= getImageMimeType(product.images[0].name) %>;base64,<%= product.images[0].file %>"
                                        class="card-img-top product-img" alt="<%= product.name %>">
                                    <% } else { %>
                                    <img src="/images/no-image.png"
                                        class="card-img-top product-img" alt="<%= product.name %>">
                                    <% } %>

                                    <div class="card-body">

                                        <div class="product-price">
                                            $<%= Number(product.price).toFixed(2) %>
                                        </div>

                                        <h6 class="card-title product-title">
                                            <%= product.name %>
                                        </h6>

                                    </div>

                                </div>

                            </a>

                        </div>

                        <% }) %>

                            <% } else { %>

                                <div class="col-12">

                                    <div class="alert alert-light text-center">

                                        No hay productos disponibles

                                    </div>

                                </div>

                                <% } %>

            </div>

        </div>

        <%- include('partials/footer') %>

            <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</body>

</html>