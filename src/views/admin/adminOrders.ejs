<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Gossip Cases</a>
    </div>
  </nav>

  <!-- Admin Panel -->
  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1><%- title %></h1>
      <a href="/admin" class="btn btn-secondary">
        ← Volver al Inicio
      </a>
    </div>

    <% if (orders.length === 0) { %>
      <div class="alert alert-info">
        No se encontraron ordenes.
      </div>
    <% } else { %>
      <div class="row">
        <% orders.forEach(order => { %>
          <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
              <div class="card-body">
                <h5 class="card-title">Orden #<%= order.id %></h5>
                <p class="card-text mb-1"><strong>Cliente:</strong> <%= order.clientName %></p>
                <p class="card-text mb-1">
                  <strong>Estado:</strong>
                  <span class="badge <%= order.status === 'pending' ? 'bg-warning' : order.status === 'confirmed' ? 'bg-success' : 'bg-danger' %>">
                    <%= order.status %>
                  </span>
                </p>
                <p class="card-text mb-1"><strong>Total:</strong> $<%= order.total %></p>
                <p class="card-text mb-1">
                  <strong>Fecha:</strong> 
                  <%= new Date(order.createdAt).toLocaleString('es-AR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </p>
                <div class="mt-2">
                  <% order.products.split(",").forEach(productId => { %>
                    <span class="badge bg-secondary me-1">Producto <%= productId %></span>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white py-4 mt-5">
    <div class="container text-center">
      <p class="mb-0">&copy; 2024 Gossip Cases. Panel de Administración.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
