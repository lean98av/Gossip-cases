<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Gossip Cases</a>
    </div>
  </nav>

  <!-- Admin Panel -->
  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1><%- title %></h1>
      <a href="/admin" class="btn btn-secondary">
        ← Volver al Inicio
      </a>
    </div>

    <% if (orders.length === 0) { %>
      <div class="alert alert-info">
        No se encontraron ordenes.
      </div>
    <% } else { %>
      <div class="row" id="ordersContainer">
        <% orders.forEach(order => { %>
          <div class="col-md-4 mb-4 order-card"
               data-id="<%= order.id %>"
               data-total="<%= order.total %>"
               data-date="<%= new Date(order.createdAt).getTime() %>"
               data-status="<%= order.status %>">
            <div class="card shadow-sm h-100" role="button" data-bs-toggle="modal" data-bs-target="#orderModal-<%= order.id %>">
              <div class="card-body">
                <h5 class="card-title">Orden #<%= order.id %></h5>
                <p class="card-text mb-1"><strong>Cliente:</strong> <%= order.clientName %></p>
                <p class="card-text mb-1">
                  <strong>Estado:</strong>
                  <span class="badge
                    <%= order.status === 'pending' ? 'bg-warning' :
                        order.status === 'inProgress' ? 'bg-info' :
                        order.status === 'payed' ? 'bg-success' : 'bg-danger' %>">
                    <%= order.status %>
                  </span>
                </p>
                <p class="card-text mb-1"><strong>Total:</strong> $<%= order.total %></p>
                <p class="card-text mb-1">
                  <strong>Fecha:</strong>
                  <%= new Date(order.createdAt).toLocaleString('es-AR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </p>
              </div>
            </div>
          </div>

          <!-- Modal -->
          <div class="modal fade" id="orderModal-<%= order.id %>" tabindex="-1" aria-labelledby="orderModalLabel-<%= order.id %>" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
              <div class="modal-content
                <%= order.status === 'pending' ? 'border-warning' :
                    order.status === 'inProgress' ? 'border-info' :
                    order.status === 'payed' ? 'border-success' : 'border-danger' %>">

                <div class="modal-header
                  <%= order.status === 'pending' ? 'bg-warning text-dark' :
                      order.status === 'inProgress' ? 'bg-info text-dark' :
                      order.status === 'payed' ? 'bg-success text-white' : 'bg-danger text-white' %>">
                  <h5 class="modal-title" id="orderModalLabel-<%= order.id %>">
                    Detalles de Orden #<%= order.id %>
                  </h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body">
                  <p><strong>Cliente:</strong> <%= order.clientName %></p>
                  <p><strong>Teléfono:</strong> <%= order.clientPhone %></p>
                  <p><strong>Dirección:</strong> <%= order.address %></p>
                  <p><strong>Notas del Cliente:</strong> <%= order.clientNotes %></p>
                  <p><strong>Total:</strong> $<%= order.total %></p>
                  <p><strong>Estado:</strong>
                    <span class="badge
                      <%= order.status === 'pending' ? 'bg-warning' :
                          order.status === 'inProgress' ? 'bg-info' :
                          order.status === 'payed' ? 'bg-success' : 'bg-danger' %>">
                      <%= order.status %>
                    </span>
                  </p>
                  <div class="mt-3">
                  <label for="statusSelect-<%= order.id %>" class="form-label">Cambiar estado:</label>
                  <select id="statusSelect-<%= order.id %>" class="form-select"
                          onchange="updateOrderStatus(<%= order.id %>, this.value)">
                    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                    <option value="inProgress" <%= order.status === 'inProgress' ? 'selected' : '' %>>In Progress</option>
                    <option value="payed" <%= order.status === 'payed' ? 'selected' : '' %>>Payed</option>
                    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                  </select>
                </div>
                  <p><strong>Fecha de creación:</strong>
                    <%= new Date(order.createdAt).toLocaleString('es-AR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                  </p>
                  <hr>
                  <h6>Productos:</h6>
                  <ul class="list-group">
                    <% order.products.forEach(p => { %>
                      <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><strong><%= p.productName %></strong> (ID: <%= p.productId %>)</span>
                        <span>$<%= p.productPrice %></span>
                      </li>
                    <% }) %>
                  </ul>
                </div>


                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
              </div>
            </div>
          </div>

        <% }) %>
      </div>

      <!-- Ver más -->
      <div class="mt-4 text-center">
        <button class="btn btn-secondary" id="loadMore" onclick="loadMoreOrders()">
          Ver más
        </button>
      </div>
    <% } %>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white py-4 mt-5">
    <div class="container text-center">
      <p class="mb-0">&copy; 2024 Gossip Cases. Panel de Administración.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let currentPage = 1;

    async function loadMoreOrders() {
      const loadMoreBtn = document.getElementById('loadMore');
      loadMoreBtn.disabled = true;
      loadMoreBtn.textContent = 'Cargando...';

      try {
        currentPage++;
        const response = await fetch(`/admin/orders/loadMore?page=${currentPage}`);
        const data = await response.json();

        if (data.orders && data.orders.length > 0) {
          const container = document.getElementById('ordersContainer');
          const newOrdersHtml = data.orders.map(order => {
            const date = new Date(order.createdAt);
            return `
              <div class="col-md-4 mb-4 order-card"
                   data-id="${order.id}"
                   data-total="${order.total}"
                   data-date="${date.getTime()}"
                   data-status="${order.status}">
                <div class="card shadow-sm h-100" role="button" data-bs-toggle="modal" data-bs-target="#orderModal-${order.id}">
                  <div class="card-body">
                    <h5 class="card-title">Orden #${order.id}</h5>
                    <p class="card-text mb-1"><strong>Cliente:</strong> ${order.clientName}</p>
                    <p class="card-text mb-1">
                      <strong>Estado:</strong>
                      <span class="badge
                        ${order.status === 'pending' ? 'bg-warning' :
                            order.status === 'inProgress' ? 'bg-info' :
                            order.status === 'payed' ? 'bg-success' : 'bg-danger'}">
                        ${order.status}
                      </span>
                    </p>
                    <p class="card-text mb-1"><strong>Total:</strong> $${order.total}</p>
                    <p class="card-text mb-1">
                      <strong>Fecha:</strong>
                      ${date.toLocaleString('es-AR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' })}
                    </p>
                  </div>
                </div>
              </div>
            `;
          }).join('');
          
          container.insertAdjacentHTML('beforeend', newOrdersHtml);
        }
      } catch (error) {
        console.error(error);
        alert('Error al cargar más órdenes');
      } finally {
        loadMoreBtn.disabled = false;
        loadMoreBtn.textContent = 'Ver más';
      }
    }

    async function updateOrderStatus(orderId, newStatus) {
      try {
        const response = await fetch(`/admin/orders/${orderId}/update`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ id: orderId, status: newStatus })
        });

        if (!response.ok) {
          throw new Error('Error al actualizar el estado');
        }

        const result = await response.json();

        // Actualizar el badge en la card y modal
        const badgeElements = document.querySelectorAll(
          `[data-id="${orderId}"] .badge, #orderModal-${orderId} .badge`
        );
        badgeElements.forEach(badge => {
          badge.textContent = newStatus;
          badge.className = 'badge ' + (
            newStatus === 'pending' ? 'bg-warning' :
            newStatus === 'inProgress' ? 'bg-info' :
            newStatus === 'payed' ? 'bg-success' : 'bg-danger'
          );
        });
      } catch (error) {
        console.error(error);
        alert('No se pudo actualizar el estado');
      }
    }
  </script>
</body>
</html>
