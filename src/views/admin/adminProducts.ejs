<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Gossip Cases</a>
    </div>
  </nav>

  <!-- Admin Panel -->
  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1><%- title %></h1>
      <a href="/admin" class="btn btn-secondary">
        ← Volver al Inicio
      </a>
    </div>

    <% if (products.length === 0) { %>
      <div class="alert alert-info">
        No se encontraron productos.
      </div>
    <% } else { %>
      <div class="row">
        <% products.forEach(product => { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <% if (product.image) { %>
                  <img src="<%= product.image %>" alt="<%= product.name %>" class="img-fluid mb-3 rounded" style="max-height: 200px; object-fit: cover;">
                <% } %>
                <h5 class="card-title"><%= product.name %></h5>
                <p class="card-text">
                  <strong class="text-primary">$<%= product.price.toFixed(2) %></strong>
                </p>
                <% if (product.description) { %>
                  <p class="card-text text-muted">
                    <%= product.description %>
                  </p>
                <% } %>
                <p class="card-text">
                  <small class="text-muted">
                    Categoría: 
                    <% if (product.category) { %>
                      <%= product.category.name %>
                    <% } else { %>
                      Sin categoría
                    <% } %>
                  </small>
                </p>
                <div class="d-flex gap-2">
                  <span class="badge <%= product.outStock ? 'bg-danger' : 'bg-success' %>">
                    <%= product.outStock ? 'Sin Stock' : 'En Stock' %>
                  </span>
                  <span class="badge <%= product.showToClients ? 'bg-info' : 'bg-secondary' %>">
                    <%= product.showToClients ? 'Visible' : 'Oculto' %>
                  </span>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white py-4 mt-5">
    <div class="container text-center">
      <p class="mb-0">&copy; 2024 Gossip Cases. Panel de Administración.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
