<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Gossip Cases</a>
    </div>
  </nav>

  <!-- Admin Panel -->
  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1><%- title %></h1>
      <a href="/admin" class="btn btn-secondary">← Volver al Inicio</a>
    </div>

    <% if (adminAuth) { %>
      <a href="/admin/products/create" class="btn btn-primary">
        ➕ Crear Producto
      </a>
      <a href="/admin/logout" class="btn btn-danger">
        🚪 Cerrar Sesión
      </a>
    <% } else { %>
      <a href="/admin/login" class="btn btn-primary">
        🔐 Iniciar Sesión
      </a>
    <% } %>
  </div>

  <!-- Product List -->
  <div class="container mt-4">
    <% if (products.length === 0) { %>
      <div class="alert alert-info">No se encontraron productos.</div>
    <% } else { %>
      <div class="row">
        <% products.forEach(product => { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <% if (product.images && product.images.length > 0) { %>
                  <img src="<%= product.images[0].file %>" alt="<%= product.name %>" class="img-fluid mb-3 rounded" style="max-height: 200px; object-fit: cover;">
                <% } %>
                <h5 class="card-title"><%= product.name %></h5>
                <p class="card-text"><strong class="text-primary">$<%= product.price %></strong></p>
                <% if (product.description) { %>
                  <p class="card-text text-muted"><%= product.description %></p>
                <% } %>
                <p class="card-text">
                  <small class="text-muted">
                    Categoría: <%= product.category ? product.category.name : 'Sin categoría' %>
                  </small>
                </p>
                <div class="d-flex gap-2">
                  <span class="badge <%= product.outStock ? 'bg-danger' : 'bg-success' %>">
                    <%= product.outStock ? 'Sin Stock' : 'En Stock' %>
                  </span>
                  <span class="badge <%= product.showToClients ? 'bg-info' : 'bg-secondary' %>">
                    <%= product.showToClients ? 'Visible' : 'Oculto' %>
                  </span>
                  <a href="/admin/products/<%= product.id %>/edit" class="btn btn-sm btn-warning">
                    ✏️ Editar
                  </a>
                  <button onclick="deleteProduct(<%= product.id %>)" class="btn btn-sm btn-danger">
                    🗑️ Eliminar
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <script>
    function deleteProduct(id) {
      if (confirm('¿Estás seguro de que deseas eliminar este producto?')) {
        fetch('/admin/products/' + id, { method: 'DELETE' })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert('Producto eliminado correctamente');
              window.location.reload();
            } else {
              alert('Error al eliminar producto: ' + data.message);
            }
          })
          .catch(err => {
            alert('Error al eliminar producto');
          });
      }
    }
  </script>

  <!-- Footer -->
  <footer class="bg-dark text-white py-4 mt-5">
    <div class="container text-center">
      <p class="mb-0">&copy; 2024 Gossip Cases. Panel de Administración.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
