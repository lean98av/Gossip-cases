<!-- ===================================
     FOOTER
=================================== -->

<footer class="footer-custom">

    <div class="container">

        <div class="row align-items-center gy-4">

            <!-- BRAND -->

            <div class="col-lg-4 text-center text-lg-start">

                <h3 class="footer-logo">
                    Gossip Cases
                </h3>

                <p class="footer-text mb-0">
                    Accesorios y fundas.
                </p>

            </div>

            <!-- SOCIAL -->

            <div class="col-lg-4 text-center">

                <div class="footer-socials">

                    <% if (appSettings.instagram) { %>
                        <a
                            href="<%= appSettings.instagram %>"
                            target="_blank"
                            class="footer-icon">

                            <i class="fab fa-instagram"></i>

                        </a>

                    <% } %>

                    <% if (appSettings.whatsapp) { %>

                        <a
                            href="https://wa.me/<%= appSettings.whatsapp %>"
                            target="_blank"
                            class="footer-icon">

                            <i class="fab fa-whatsapp"></i>

                        </a>

                    <% } %>

                    <% if (appSettings.tiktok) { %>

                        <a
                            href="<%= appSettings.tiktok %>"
                            target="_blank"
                            class="footer-icon">

                            <i class="fab fa-tiktok"></i>

                        </a>

                    <% } %>

                </div>

            </div>

            <!-- COPYRIGHT -->

            <div class="col-lg-4 text-center text-lg-end">

                <p class="footer-copy mb-0">
                    © 2026 Gossip Cases · Todos los derechos reservados
                </p>

            </div>

        </div>

    </div>

</footer>