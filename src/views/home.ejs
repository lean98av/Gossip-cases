    <!-- MAIN CONTENT -->
    <div class="container mt-4 mb-5">

        <div class="row g-4">

            <!-- CARGADORES -->
            <div class="col-md-6">
                <a href="Cargadores.html" class="category-card">

                    <img src="/images/cargadores.png" alt="Cargadores">

