<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gossip Cases - Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .hero {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 80px 0;
      margin-bottom: 40px;
    }
    .card {
      transition: transform 0.2s;
    }
    .card:hover {
      transform: translateY(-5px);
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Gossip Cases</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/products">Products</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/cart">Cart</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h1 class="display-4 fw-bold">¡Bienvenido a Gossip Cases!</h1>
          <p class="lead">La mejor experiencia de e-commerce en TypeScript + Sequelize + PostgreSQL</p>
        </div>
        <div class="col-md-4 text-md-end">
          <button class="btn btn-light btn-lg" onclick="window.location.href='/products'">Ver Productos</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="container mb-5">
    <h2 class="text-center mb-4">Características</h2>
    <div class="row">
      <div class="col-md-4 mb-3">
        <div class="card h-100">
          <div class="card-body text-center">
            <h5 class="card-title">🚀 Rápido</h5>
            <p class="card-text">Optimizado para el mejor rendimiento</p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card h-100">
          <div class="card-body text-center">
            <h5 class="card-title">🔒 Seguro</h5>
            <p class="card-text">Protección de datos de primer nivel</p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card h-100">
          <div class="card-body text-center">
            <h5 class="card-title">🎨 Moderno</h5>
            <p class="card-text">Diseño limpio y atractivo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-light py-5">
    <div class="container">
      <div class="row text-center">
        <div class="col-md-4 mb-3">
          <h3 class="text-primary">1,000+</h3>
          <p>Productos</p>
        </div>
        <div class="col-md-4 mb-3">
          <h3 class="text-success">99.9%</h3>
          <p>Uptime</p>
        </div>
        <div class="col-md-4 mb-3">
          <h3 class="text-danger">24/7</h3>
          <p>Soporte</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container mb-5">
    <div class="card p-5 text-center">
      <h2>¿Listo para empezar?</h2>
      <p class="lead">Explora nuestros productos y descubre todo lo que podemos ofrecerte</p>
      <button class="btn btn-primary btn-lg" onclick="window.location.href='/products'">Comenzar Ahora</button>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-dark text-white py-4 mt-5">
    <div class="container text-center">
      <p class="mb-0">&copy; 2024 Gossip Cases. Todos los derechos reservados.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
